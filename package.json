{
  "name": "term-project",
  "version": "1.0.0",
  "description": "CSC 667 Term Project - Spring 2026",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc && npm run build:client",
    "build:client": "esbuild src/client/main.ts --bundle --outdir=public/js --platform=browser --format=iife",
    "start": "npm run migrate && tsx src/server.ts",
    "dev": "concurrently --names \"server,client,reload\" --prefix-colors \"cyan,yellow,green\" \"npm:watch:server\" \"npm:watch:client\" \"npm:watch:reload\"",
    "watch:server": "cross-env NODE_ENV=development nodemon --watch src --ignore src/client --exec tsx src/server.ts",
    "watch:client": "esbuild src/client/main.ts --bundle --outdir=public/js --platform=browser --format=iife --watch",
    "watch:reload": "livereload public/ views/ --wait 300",
    "test": "tsx --test tests/*.test.ts",
    "test:watch": "tsx --test --watch tests/*.test.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist/",
    "prepare": "husky || true",
    "migrate": "node ./database/migration.js"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/connect-livereload": "^0.6.3",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "livereload": "^0.10.3",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-livereload": "^0.6.1",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "pg": "^8.20.0",
    "pg-promise": "^12.6.2"
  }
}
