<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css" />
    <style>
      * {
        box-sizing: border-box;
      }

      .page-shell {
        min-height: 100vh;
      }

      .site-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
      }

      .site-nav a,
      .site-nav button {
        color: white;
        text-decoration: none;
        font: inherit;
      }

      .site-nav__links,
      .site-nav__actions {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
      }

      .site-nav__actions span,
      .site-nav__actions form {
        margin: 0;
      }

      .site-nav__actions span {
        color: white;
      }

      .site-nav__button {
        border: 1px solid rgba(255, 255, 255, 0.35);
        background: transparent;
        color: white;
        padding: 8px 14px;
        border-radius: 6px;
        cursor: pointer;
        font: inherit;
      }

      .site-nav__button--primary {
        background-color: #2d6cdf;
        border-color: #2d6cdf;
      }

      .content {
        width: min(960px, calc(100% - 32px));
        margin: 40px auto;
      }

      .content--home {
        width: 100%;
        margin: 0;
      }

      .card {
        background: white;
        border-radius: 14px;
        padding: 28px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      }

      .auth-card {
        width: min(480px, 100%);
        margin: 0 auto;
      }

      .auth-card h1 {
        margin-top: 0;
      }

      .form-grid {
        display: grid;
        gap: 14px;
      }

      .form-grid label {
        font-weight: 700;
      }

      .form-grid input {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid #cfd6e4;
        margin-top: 6px;
      }

      .primary-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 0;
        background: #2563eb;
        color: white;
        padding: 12px 16px;
        border-radius: 8px;
        cursor: pointer;
        font: inherit;
        text-decoration: none;
      }

      .secondary-link-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 16px;
        border-radius: 8px;
        border: 1px solid #cfd6e4;
        color: #1d2735;
        text-decoration: none;
      }

      .error-banner {
        margin-bottom: 16px;
        padding: 12px 14px;
        border-radius: 8px;
        background: #fee2e2;
        color: #b91c1c;
      }

      .helper-text {
        color: #526072;
      }

      .profile-row {
        display: flex;
        align-items: center;
        gap: 18px;
      }

      .profile-row img {
        width: 88px;
        height: 88px;
        border-radius: 50%;
      }

      .profile-meta p {
        margin: 4px 0;
      }

      .home-profile {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 10px;
      }

      .home-profile__avatar {
        width: 88px;
        height: 88px;
        border-radius: 50%;
      }

      .home-profile__meta p {
        margin: 0;
        font-size: 18px;
      }

      .simple-page {
        padding: 24px;
      }

      .auth-modal {
        position: fixed;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
        z-index: 50;
      }

      .auth-modal.is-open {
        display: flex;
      }

      .auth-modal__backdrop {
        position: absolute;
        inset: 0;
        background: rgba(15, 23, 42, 0.45);
      }

      .auth-modal__panel {
        position: relative;
        z-index: 1;
        width: min(460px, 100%);
        max-width: 420px;
        background: white;
        border-radius: 10px;
        padding: 24px;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
      }

      .auth-modal__close {
        position: absolute;
        top: 10px;
        right: 12px;
        border: 0;
        background: transparent;
        font-size: 24px;
        cursor: pointer;
      }

      .auth-switcher {
        display: flex;
        gap: 12px;
      }

      .auth-switcher.auth-tabs {
        margin-bottom: 18px;
      }

      .auth-switcher__tab {
        border: 1px solid #ccc;
        background: #f5f5f5;
        color: #333;
        padding: 8px 12px;
        border-radius: 6px;
        cursor: pointer;
        font: inherit;
      }

      .auth-switcher__tab.is-active {
        background-color: #2d6cdf;
        border-color: #2d6cdf;
        color: white;
      }

      @media (max-width: 640px) {
        .site-nav {
          flex-direction: column;
          align-items: flex-start;
        }

        .profile-row {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <div class="page-shell">
      <nav class="<%= typeof navClass !== 'undefined' ? navClass : 'site-nav' %>">
        <div class="<%= typeof navLinksClass !== 'undefined' ? navLinksClass : 'site-nav__links' %>">
          <a href="/" <%= typeof showAccountButton !== "undefined" && showAccountButton ? 'data-requires-login="true"' : '' %>>Home</a>
          <a href="/about" <%= typeof showAccountButton !== "undefined" && showAccountButton ? 'data-requires-login="true"' : '' %>>About</a>
          <a href="/rules" <%= typeof showAccountButton !== "undefined" && showAccountButton ? 'data-requires-login="true"' : '' %>>Rules</a>
        </div>
        <div class="site-nav__actions">
          <% if (typeof user !== "undefined" && user) { %>
            <span><%= user.email %></span>
            <form method="post" action="/auth/logout">
              <button class="site-nav__button" type="submit">Log Out</button>
            </form>
          <% } else if (typeof showAccountButton !== "undefined" && showAccountButton) { %>
            <button id="open-login" class="site-nav__button" type="button">
              Login
            </button>
            <button id="open-register" class="site-nav__button site-nav__button--primary" type="button">
              Register
            </button>
          <% } else { %>
            <a href="/auth/login">Login</a>
            <a href="/auth/register">Register</a>
          <% } %>
        </div>
      </nav>
      <main class="content <%= typeof pageClass !== 'undefined' ? pageClass : '' %>">
