<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <nav class="home-nav">
      <div class="home-nav-left">
        <span class="nav-logo">♠ Gin Rummy</span>
        <div class="home-nav-links">
          <a href="/" aria-current="page">Home</a>
          <a href="/about">About</a>
          <a href="/rules">Rules</a>
        </div>
      </div>
      <div class="home-nav-auth">
        <div id="session-banner"></div>
        <a href="/profile" class="auth-button profile-link" id="profile-link" hidden>Profile</a>
        <button id="open-login" class="auth-button" type="button">Login</button>
        <button id="open-register" class="auth-button auth-button-register" type="button">
          Register
        </button>
        <button id="logout-button" class="auth-button" type="button" hidden>Log Out</button>
      </div>
    </nav>

    <template id="session-banner-tpl">
      <span class="session-badge">
        <span data-status></span>
        <span data-email></span>
      </span>
    </template>

    <div id="app">
      <div id="sidebar">
        <button id="btn-new-game" type="button">New Game</button>
        <button id="btn-sort" type="button">Sort Hand</button>
        <hr />
        <p class="rule-label"><strong>How to Play:</strong></p>
        <p class="rule-label">
          On your turn, click the <strong>deck</strong> (Stock) or the <strong>face-up card</strong>
          (Discard) in the center to draw.
        </p>
        <p class="rule-label">
          Then click a card in your hand to select it, and press <strong>Discard</strong>.
        </p>
        <p class="rule-label">Sort by suit/rank with <strong>Sort Hand</strong>.</p>
        <p class="rule-label">First player to a clean meld can <strong>Knock</strong>.</p>
      </div>

      <main id="table" class="game-table">
        <!-- Empty state shown before a game starts -->
        <div id="table-empty" class="table-empty">
          <h2>♠ Gin Rummy</h2>
          <p>Click <strong>New Game</strong> in the sidebar to create or join a room.</p>
        </div>

        <!-- Live game view, hidden until a game is active -->
        <div id="table-game" class="table-game" hidden>
          <header class="table-header">
            <div class="table-room">Room: <strong id="hud-room">—</strong></div>
            <div class="table-turn">
              <span class="turn-dot" id="hud-turn-dot"></span>
              <span id="hud-turn-text">Waiting…</span>
            </div>
            <div class="table-deadwood">Deadwood: <strong id="hud-deadwood">—</strong></div>
            <button id="btn-leave-game" type="button" class="hud-leave-btn">Leave</button>
          </header>

          <section class="table-play-area" aria-label="Game table">
            <div class="seat-area opponent-hand" id="opponent-hand"></div>

            <section class="table-center">
              <div class="pile pile-deck" id="pile-deck" title="Draw Stock">
                <div class="pile-card pile-card-back"></div>
                <div class="pile-label">Stock <span id="deck-count">0</span></div>
              </div>
              <div class="pile pile-discard" id="pile-discard" title="Draw Discard">
                <div class="pile-card" id="discard-top"></div>
                <div class="pile-label">Discard</div>
              </div>
            </section>

            <section class="seat-area table-self">
              <div class="hand self-hand" id="self-hand"></div>
              <div class="player-label" id="hud-self-name">You</div>
            </section>
          </section>

          <section class="table-actions" aria-label="Game actions">
            <p class="table-actions-hint">Draw, choose one card, then discard or declare.</p>
            <div id="action-buttons">
              <button id="btn-discard" class="game-action-btn action-discard" type="button" disabled>
                Discard selected
              </button>
              <button id="btn-knock" class="game-action-btn action-declare" type="button" disabled>
                Gin / Knock
              </button>
            </div>
          </section>

          <div id="table-message" class="table-message" hidden></div>
          <section id="round-results" class="round-results" hidden>
            <h3>Round Results</h3>
            <div id="round-results-list" class="round-results-list"></div>
          </section>
        </div>
      </main>

      <!-- Chat Panel -->
      <div id="chat-panel" class="chat-panel">
        <div class="chat-header">
          <div>
            <h3>Room Chat</h3>
            <p id="chat-room-label" class="chat-room-label">No active room</p>
          </div>
          <div class="chat-header-actions">
            <span id="chat-unread" class="chat-unread" hidden>0</span>
            <button
              id="chat-toggle"
              class="chat-toggle"
              type="button"
              title="Toggle chat"
              aria-label="Toggle chat"
              aria-expanded="true"
            >
              −
            </button>
            <button
              id="chat-close"
              class="chat-close"
              type="button"
              title="Close chat"
              aria-label="Close chat"
            >
              ×
            </button>
          </div>
        </div>
        <div id="chat-status" class="chat-status" role="status" aria-live="polite">
          Start or join a game room to chat with other players.
        </div>
        <div id="chat-messages" class="chat-messages" aria-live="polite"></div>
        <div class="chat-input-wrapper">
          <input
            id="chat-input"
            type="text"
            class="chat-input"
            placeholder="Message the room"
            maxlength="500"
            autocomplete="off"
            aria-label="Chat message"
            disabled
          />
          <button id="chat-send" class="chat-send" type="button" disabled>Send</button>
          <div class="chat-input-meta">
            <span id="chat-error" class="chat-error" role="alert"></span>
            <span id="chat-count" class="chat-count">0/500</span>
          </div>
        </div>
      </div>
      <button id="chat-launcher" class="chat-launcher" type="button" hidden>
        <span>Chat</span>
        <span id="chat-launcher-unread" class="chat-launcher-unread" hidden>0</span>
      </button>
    </div>

    <div id="auth-modal" class="auth-modal" hidden>
      <div class="auth-modal-backdrop" data-close-modal="true"></div>
      <div class="auth-modal-panel" role="dialog" aria-modal="true" aria-labelledby="auth-title">
        <button class="auth-modal-close" type="button" data-close-modal="true">×</button>
        <div class="auth-tabs">
          <button id="login-tab" class="auth-tab active" type="button">Login</button>
          <button id="register-tab" class="auth-tab" type="button">Register</button>
        </div>

        <section id="login-panel" class="auth-panel">
          <div id="login-content"></div>
        </section>

        <section id="register-panel" class="auth-panel" hidden>
          <div id="register-content"></div>
        </section>
      </div>
    </div>

    <div id="game-room-modal" class="game-room-modal" hidden>
      <div class="game-room-backdrop" data-close-modal="true"></div>
      <div
        class="game-room-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="game-room-title"
      >
        <button class="game-room-close" type="button" data-close-modal="true">×</button>
        <h2 id="game-room-title">Find a Game</h2>

        <div class="game-room-tabs">
          <button id="tab-join" class="game-room-tab active" type="button">Join Game</button>
          <button id="tab-create" class="game-room-tab" type="button">Create Room</button>
          <button id="tab-waiting" class="game-room-tab" type="button">Waiting for Match</button>
        </div>

        <!-- Tab 1: Join Game by Room ID -->
        <section id="panel-join" class="game-room-panel-content active">
          <h3>Join Game by Room ID</h3>
          <div class="game-room-form">
            <input
              id="input-room-id"
              type="text"
              placeholder="Enter Room ID (e.g., ABC123)"
              maxlength="8"
            />
            <button id="btn-join-room" type="button" class="game-room-action-btn">Join</button>
          </div>
          <div id="join-error" class="game-room-error" hidden></div>
          <div id="join-loading" class="game-room-loading" hidden>Joining room...</div>
        </section>

        <!-- Tab 2: Create Room -->
        <section id="panel-create" class="game-room-panel-content">
          <h3>Create a New Room</h3>
          <p class="game-room-info">You'll get a Room ID to share with another player.</p>
          <button id="btn-create-room" type="button" class="game-room-action-btn">
            Create Room
          </button>
          <button id="btn-practice-solo" type="button" class="game-room-action-btn solo-action-btn">
            Practice Solo
          </button>
          <div id="create-error" class="game-room-error" hidden></div>
          <div id="create-loading" class="game-room-loading" hidden>Creating room...</div>
          <div id="create-success" class="game-room-success" hidden>
            <p>Room Created!</p>
            <p>Your Room ID: <strong id="room-id-display"></strong></p>
            <p class="game-room-info">Share this ID with another player to start a game.</p>
            <div class="game-room-waiting-indicator">
              <div class="game-room-spinner"></div>
              <p>Waiting for opponent...</p>
            </div>
          </div>
        </section>

        <!-- Tab 3: Waiting for Match -->
        <section id="panel-waiting" class="game-room-panel-content">
          <h3>Waiting for Match</h3>
          <p class="game-room-info">We're looking for an opponent for you...</p>
          <div class="game-room-waiting-indicator">
            <div class="game-room-spinner"></div>
            <p>Matching you with a player...</p>
          </div>
          <button id="btn-cancel-wait" type="button" class="game-room-cancel-btn">Cancel</button>
        </section>
      </div>
    </div>

    <script defer src="/js/main.js"></script>
    <script type="module" src="/js/auth-ui.js"></script>
    <script type="module" src="/js/game-room.js"></script>
    <script type="module" src="/js/game-init.js"></script>
    <script type="module" src="/js/chat.js"></script>
  </body>
</html>
